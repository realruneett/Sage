FROM rocm/pytorch:rocm6.2_ubuntu22.04_py3.10_pytorch_2.4.0

ENV PYTORCH_ROCM_ARCH="gfx942"
ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /app

RUN apt-get update && apt-get install -y \
    git python3-pip firejail libgl1-mesa-glx \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir vllm==0.6.0 --index-url https://download.pytorch.org/whl/rocm6.2

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 8000 7860

CMD ["python3", "-m", "sage.api.server"]
